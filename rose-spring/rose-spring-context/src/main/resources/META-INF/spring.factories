# ApplicationContextAware自动注册
org.springframework.context.ApplicationContextAware=\
io.zhijun.spring.core.context.SpringContextHolder

# 环境属性源变更监听器
io.zhijun.spring.core.env.EnvironmentListener=\
io.zhijun.spring.core.propertysource.PropertySourcesRefreshEnvironmentListener

# 配置绑定刷新
io.zhijun.spring.core.propertysource.Refreshable=\
io.zhijun.spring.core.binder.ConfigurationBeanBindingRefreshable
