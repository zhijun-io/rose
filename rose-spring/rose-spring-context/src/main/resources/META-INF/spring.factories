# ApplicationContextAware自动注册
org.springframework.context.ApplicationContextAware=\
io.zhijun.spring.context.SpringContextHolder

# 环境属性源变更监听器
io.zhijun.spring.env.EnvironmentListener=\
io.zhijun.spring.propertysource.PropertySourcesRefreshEnvironmentListener

# 配置绑定刷新
io.zhijun.spring.propertysource.Refreshable=\
io.zhijun.spring.binder.ConfigurationBeanBindingRefreshable
