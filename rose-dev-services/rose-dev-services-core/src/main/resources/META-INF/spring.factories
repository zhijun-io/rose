org.springframework.boot.env.EnvironmentPostProcessor=\
io.zhijun.dev.services.core.docker.DevServicesDockerEnvironmentPostProcessor,\
io.zhijun.dev.services.autoconfigure.bootstrap.BootstrapEnvironmentPostProcessor

org.springframework.boot.autoconfigure.EnableAutoConfiguration=\
io.zhijun.dev.services.core.autoconfigure.DevServicesAutoConfiguration,\
io.zhijun.dev.services.autoconfigure.bootstrap.BootstrapAutoConfiguration

org.springframework.boot.diagnostics.FailureAnalyzer=\
io.zhijun.dev.services.core.autoconfigure.MultipleDevServicesFailureAnalyzer
