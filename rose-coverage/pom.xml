<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>io.zhijun</groupId>
        <artifactId>rose-parent</artifactId>
        <version>${revision}</version>
        <relativePath>../pom.xml</relativePath>
    </parent>

    <artifactId>rose-coverage</artifactId>
    <packaging>pom</packaging>
    <name>Rose Coverage</name>
    <description>Aggregated JaCoCo coverage report for Rose</description>

    <properties>
        <maven.deploy.skip>true</maven.deploy.skip>
        <central.publishing.skip>true</central.publishing.skip>
    </properties>

    <dependencies>
        <dependency>
            <groupId>io.zhijun</groupId>
            <artifactId>rose-core</artifactId>
        </dependency>
        <dependency>
            <groupId>io.zhijun</groupId>
            <artifactId>rose-spring-boot</artifactId>
        </dependency>
        <dependency>
            <groupId>io.zhijun</groupId>
            <artifactId>rose-data-jdbc-sqlite</artifactId>
        </dependency>
        <dependency>
            <groupId>io.zhijun</groupId>
            <artifactId>rose-observation-core</artifactId>
        </dependency>
        <dependency>
            <groupId>io.zhijun</groupId>
            <artifactId>rose-opentelemetry-core</artifactId>
        </dependency>
        <dependency>
            <groupId>io.zhijun</groupId>
            <artifactId>rose-opentelemetry-logback-bridge</artifactId>
        </dependency>
        <dependency>
            <groupId>io.zhijun</groupId>
            <artifactId>rose-opentelemetry-micrometer-metrics-bridge</artifactId>
        </dependency>
        <dependency>
            <groupId>io.zhijun</groupId>
            <artifactId>rose-opentelemetry-micrometer-registry-otlp</artifactId>
        </dependency>
        <dependency>
            <groupId>io.zhijun</groupId>
            <artifactId>rose-opentelemetry-semantic-conventions</artifactId>
        </dependency>
        <dependency>
            <groupId>io.zhijun</groupId>
            <artifactId>rose-multitenancy-core</artifactId>
        </dependency>
        <dependency>
            <groupId>io.zhijun</groupId>
            <artifactId>rose-multitenancy-web</artifactId>
        </dependency>
        <dependency>
            <groupId>io.zhijun</groupId>
            <artifactId>rose-dev-services-api</artifactId>
        </dependency>
        <dependency>
            <groupId>io.zhijun</groupId>
            <artifactId>rose-dev-services-core</artifactId>
        </dependency>
        <dependency>
            <groupId>io.zhijun</groupId>
            <artifactId>rose-dev-services-postgresql</artifactId>
        </dependency>
        <dependency>
            <groupId>io.zhijun</groupId>
            <artifactId>rose-dev-services-mysql</artifactId>
        </dependency>
        <dependency>
            <groupId>io.zhijun</groupId>
            <artifactId>rose-dev-services-redis</artifactId>
        </dependency>
        <dependency>
            <groupId>io.zhijun</groupId>
            <artifactId>rose-dev-services-mongodb</artifactId>
        </dependency>
        <dependency>
            <groupId>io.zhijun</groupId>
            <artifactId>rose-dev-services-kafka</artifactId>
        </dependency>
        <dependency>
            <groupId>io.zhijun</groupId>
            <artifactId>rose-dev-services-rabbitmq</artifactId>
        </dependency>
        <dependency>
            <groupId>io.zhijun</groupId>
            <artifactId>rose-dev-services-artemis</artifactId>
        </dependency>
        <dependency>
            <groupId>io.zhijun</groupId>
            <artifactId>rose-dev-services-activemq</artifactId>
        </dependency>
        <dependency>
            <groupId>io.zhijun</groupId>
            <artifactId>rose-dev-services-ollama</artifactId>
        </dependency>
        <dependency>
            <groupId>io.zhijun</groupId>
            <artifactId>rose-dev-services-mqtt</artifactId>
        </dependency>
        <dependency>
            <groupId>io.zhijun</groupId>
            <artifactId>rose-dev-services-openlit</artifactId>
        </dependency>
        <dependency>
            <groupId>io.zhijun</groupId>
            <artifactId>rose-dev-services-otel-collector</artifactId>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.jacoco</groupId>
                <artifactId>jacoco-maven-plugin</artifactId>
                <executions>
                    <execution>
                        <id>prepare-agent</id>
                        <configuration>
                            <skip>true</skip>
                        </configuration>
                    </execution>
                    <execution>
                        <id>report</id>
                        <configuration>
                            <skip>true</skip>
                        </configuration>
                    </execution>
                    <execution>
                        <id>jacoco-check</id>
                        <configuration>
                            <skip>true</skip>
                        </configuration>
                    </execution>
                    <execution>
                        <id>report-aggregate</id>
                        <phase>verify</phase>
                        <goals>
                            <goal>report-aggregate</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-antrun-plugin</artifactId>
                <version>3.1.0</version>
                <executions>
                    <execution>
                        <id>check-aggregate-line-coverage</id>
                        <phase>verify</phase>
                        <goals>
                            <goal>run</goal>
                        </goals>
                        <configuration>
                            <target>
                                <script language="javascript"><![CDATA[
                                    var Files = java.nio.file.Files;
                                    var StandardCharsets = java.nio.charset.StandardCharsets;
                                    var Pattern = java.util.regex.Pattern;
                                    var reportFile = new java.io.File(project.getProperty("project.build.directory")
                                            + "/site/jacoco-aggregate/jacoco.xml");
                                    if (!reportFile.isFile()) {
                                        throw "Missing JaCoCo aggregate report: " + reportFile;
                                    }

                                    var reportXml = new java.lang.String(
                                            Files.readAllBytes(reportFile.toPath()),
                                            StandardCharsets.UTF_8);
                                    var matcher = Pattern.compile(
                                            "<counter type=\"LINE\" missed=\"([0-9]+)\" covered=\"([0-9]+)\"/>")
                                            .matcher(reportXml);
                                    var missed = null;
                                    var covered = null;
                                    while (matcher.find()) {
                                        missed = matcher.group(1);
                                        covered = matcher.group(2);
                                    }
                                    if (missed === null || covered === null) {
                                        throw "Missing aggregate LINE counter in " + reportFile;
                                    }

                                    missed = java.lang.Integer.parseInt(missed);
                                    covered = java.lang.Integer.parseInt(covered);
                                    var total = covered + missed;
                                    var ratio = total === 0 ? 0.0 : covered / total;
                                    var minimum = java.lang.Double.parseDouble(
                                            project.getProperty("jacoco.minimum.line.coverage"));

                                    project.log("Aggregate line coverage ratio: " + ratio
                                            + " (minimum: " + minimum + ")");

                                    if (ratio + 1.0e-12 < minimum) {
                                        throw "Aggregate line coverage " + ratio
                                                + " is below minimum " + minimum;
                                    }
                                ]]></script>
                            </target>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>
</project>
