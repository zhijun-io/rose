            </dependency>
            <dependency>
                <groupId>io.zhijun</groupId>
                <artifactId>rose-dev-services-mongodb</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>io.zhijun</groupId>
                <artifactId>rose-dev-services-kafka</artifactId>
