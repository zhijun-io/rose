org.springframework.boot.env.EnvironmentPostProcessor=\
io.zhijun.devservice.core.docker.DevServiceDockerEnvironmentPostProcessor,\
io.zhijun.devservice.boot.autoconfigure.bootstrap.BootstrapEnvironmentPostProcessor

org.springframework.boot.autoconfigure.EnableAutoConfiguration=\
io.zhijun.devservice.boot.autoconfigure.DevServiceAutoConfiguration,\
io.zhijun.devservice.boot.autoconfigure.bootstrap.BootstrapAutoConfiguration

org.springframework.boot.diagnostics.FailureAnalyzer=\
io.zhijun.devservice.boot.autoconfigure.MultipleDevServiceFailureAnalyzer
